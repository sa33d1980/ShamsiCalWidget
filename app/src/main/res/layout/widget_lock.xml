<?xml version="1.0" encoding="utf-8"?>
<!-- ویجت لاک اسکرین — یک ردیفه: [روز هفته] [عدد] [ماه] -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_lock_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center"
    android:padding="4dp">

    <TextView
        android:id="@+id/tv_lock_day_of_week"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/vazirmatn_medium"
        android:text="چهارشنبه"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_marginEnd="6dp" />

    <TextView
        android:id="@+id/tv_lock_day_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/vazirmatn_bold"
        android:text="۴"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_marginEnd="4dp" />

    <TextView
        android:id="@+id/tv_lock_month"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/vazirmatn_medium"
        android:text="خرداد"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp" />

</LinearLayout>
